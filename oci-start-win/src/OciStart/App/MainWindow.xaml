<Window x:Class="OciStart.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCI-Start"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
  <Grid>
    <Grid x:Name="LoginHost" />
    <Grid x:Name="ShellHost" Visibility="Collapsed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0"
              Background="{StaticResource SidebarBgBrush}"
              BorderBrush="{StaticResource AppBorderBrush}"
              BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
            <TextBlock Text="OCI-Start"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock x:Name="SidebarUserText"
                       Margin="0,4,0,4"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <ComboBox x:Name="CloudBox"
                      Margin="0,0,0,8"
                      Padding="8,6,8,6"
                      SelectionChanged="OnCloudChanged"
                      ToolTip="切换云厂商（过滤侧栏菜单）" />
            <TextBox x:Name="SearchBox"
                     Style="{StaticResource AppTextBox}"
                     TextChanged="OnSearchChanged"
                     ToolTip="搜索菜单" />
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom" Margin="12,8,12,16">
            <Button Content="退出登录"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Stretch"
                    Click="OnLogout" />
          </StackPanel>

          <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,8,8">
            <StackPanel x:Name="NavPanel" />
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Content -->
      <Grid Grid.Column="1" x:Name="ContentHost" Background="{StaticResource BgBrush}" />
    </Grid>
  </Grid>
</Window>
